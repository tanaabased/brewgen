{
  "name": "@tanaabased/brewgen",
  "description": "Tanaab based Brewfile generation",
  "version": "0.0.0",
  "author": "Mike Pirog @pirog",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tanaabased/brewgen.git"
  },
  "bugs": {
    "url": "https://github.com/tanaabased/brewgen/issues"
  },
  "type": "module",
  "packageManager": "bun@1.3.4",
  "engines": {
    "bun": ">=1.3.0 <1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lando/leia": "^1.0.0-beta.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "shellcheck": "^4.1.0"
  },
  "scripts": {
    "build": "bun ./scripts/build-dist.js",
    "lint:eslint": "eslint .",
    "lint:shellcheck": "shellcheck -s bash brewgen.sh",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "bun run lint:eslint && bun run format:check && bun run lint:shellcheck"
  }
}
